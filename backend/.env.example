PORT=3001
CORS_ORIGIN=http://localhost:5173
DATABASE_URL="file:./dev.db"
SESSION_SECRET=change-me-in-production

# Agent bridge (Copilot integration)
# Dev default if unset in development: campus360-dev-agent-key
CAMPUS360_AGENT_API_KEY=campus360-dev-agent-key
# When set, chat replies are forwarded to Microsoft (Copilot Studio / Power Automate HTTP trigger)
# Local test before real Copilot exists:
# MICROSOFT_AGENT_ENDPOINT=http://localhost:3001/api/agent/mock-copilot
# MICROSOFT_AGENT_ENDPOINT=https://your-bot-or-flow-endpoint
# MICROSOFT_AGENT_API_KEY=
# Direct Line secret from Copilot Studio → Channels → Direct Line (for custom Web Chat embed)
# MICROSOFT_DIRECT_LINE_SECRET=
#
# Frontend: VITE_COPILOT_CHAT_MODE=directline (default) or iframe to force legacy embed

# Google & Microsoft sign-in (see ../shared/auth-sso.md)
OAUTH_CALLBACK_BASE_URL=http://localhost:3001
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_HD=ateneo.edu.ph
# OAUTH_GOOGLE_ALLOWED_DOMAINS=ateneo.edu.ph
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_OAUTH_TENANT=common
# OAUTH_MICROSOFT_ALLOWED_DOMAINS=outlook.com,hotmail.com,live.com
# OAUTH_AUTO_PROVISION=false

# ngrok (Copilot Studio needs a public URL to hit localhost:3001)
# Get token: https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=your_ngrok_authtoken_here
